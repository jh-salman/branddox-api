# --- Local PostgreSQL (recommended for dev) ---
# Install Postgres locally, or run: docker compose up -d (see docker-compose.yml)
# Then create DB if needed: createdb branddox   (or use POSTGRES_DB from Docker)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/branddox"

# --- Remote (Neon / Supabase / etc.) ---
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"
AUTH_SECRET="change-me-in-production"
PORT=4000
N8N_WEBHOOK_URL="https://automation.branddox.com/webhook/youtube-lead"

# Cloudinary (portfolio image uploads)
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# YouTube Data API v3 (for resolving channel info from channel URL)
GOOGLE_YOUTUBE_API_KEY="your_youtube_api_key"
