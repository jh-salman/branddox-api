# --- Local PostgreSQL (recommended for dev) ---
# Install Postgres locally, or run: docker compose up -d (see docker-compose.yml)
# Then create DB if needed: createdb branddox   (or use POSTGRES_DB from Docker)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/branddox"

# --- Remote (Neon / Supabase / etc.) ---
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"
AUTH_SECRET="change-me-in-production"
PORT=4000
N8N_WEBHOOK_URL="https://automation.branddox.com/webhook/youtube-lead"

# Admin secret — required for admin-only routes (portfolio/clients/services writes,
# upload, and the YouTube channel finder). The web app forwards this as x-admin-secret.
# Set the SAME value as ADMIN_PASSWORD in the web app.
ADMIN_PASSWORD="change-me-strong-admin-password"

# Cloudinary (portfolio image uploads)
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# YouTube Data API v3 (for resolving channel info from channel URL)
GOOGLE_YOUTUBE_API_KEY="your_youtube_api_key"

# OpenAI — powers campaign service-matching + personalized email drafts
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4o-mini"          # cheap/fast model for bulk drafting
OPENAI_DEEP_MODEL="gpt-4o"          # stronger model for single-lead "Deep analyze"

# SMTP — used to send campaign emails from your own inbox.
# Gmail: create an App Password (Account → Security → App passwords) and use it as SMTP_PASS.
#   SMTP_HOST=smtp.gmail.com  SMTP_PORT=465  SMTP_SECURE=true
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER="you@yourdomain.com"
SMTP_PASS="your-app-password"
SMTP_FROM="Braddox <you@yourdomain.com>"
SMTP_MAX_PER_RUN=100                # safety cap per send (protect sender reputation)
SMTP_THROTTLE_MS=1500               # delay between emails
